TWILIO_VERIFIED_NUMBER=+919876543210

# ==========================
# Email
# ==========================
EMAIL_PROVIDER_SMTP_ADDRESS=smtp.gmail.com
MY_EMAIL=your_email@example.com
MY_EMAIL_PASSWORD=your_app_password